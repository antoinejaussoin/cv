---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../css/app.css";
import "../css/print.css";
import cv from "../data/en";
import Work from "../components/Work.astro";
import Profile from "../components/Profile.astro";
import Education from "../components/Education.astro";
import Skills from "../components/Skills.astro";
import MailTo from "../components/MailTo.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import { Picture } from "astro:assets";
import portraitSrc from "../images/portrait2026.jpeg";

const sortedWork = [...cv.work].sort((left, right) =>
  right.dates.from.localeCompare(left.dates.from),
);
const sortedEducation = [...cv.education].sort((left, right) =>
  right.date.localeCompare(left.date),
);
const coreStack = cv.subtitle
  .split("-")
  .map((item) => item.trim())
  .filter(Boolean);
const phoneHref = "tel:" + cv.phone.replace(/\s+/g, "");

function formatUrl(url: string) {
  try {
    return new URL(url).hostname.replace(/^www\./, "");
  } catch {
    return url;
  }
}

const personalSite = formatUrl(cv.website);
const wordCvPath = "/downloads/Antoine_Jaussoin_CV.rtf";
const pdfCvPath = "/downloads/Antoine_Jaussoin_CV.pdf";

const socialLinks = [
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/jantoine",
    detail: "in/jantoine",
  },
  {
    label: "GitHub",
    href: "https://github.com/antoinejaussoin",
    detail: "antoinejaussoin",
  },
  {
    label: "X",
    href: "https://twitter.com/antjaus",
    detail: "@antjaus",
  },
  {
    label: "Stack Overflow",
    href: "https://stackoverflow.com/users/641124/antoine-jaussoin",
    detail: "profile",
  },
];
---

<BaseLayout
  title={`${cv.name} | ${cv.title}`}
  description={`${cv.name} is a ${cv.title} specialising in ${cv.subtitle}.`}
>
  <div class="page-shell">
    <div class="page-glow page-glow--left"></div>
    <div class="page-glow page-glow--right"></div>

    <main class="resume-page">
      <header class="hero">
        <section class="hero__content">
          <div class="hero__identity">
            <div class="hero__identity-copy">
              <h1>{cv.name}</h1>
              <p class="hero__role">{cv.title}</p>
            </div>
          </div>

          <ul class="hero__stack" aria-label="Core stack">
            {coreStack.map((item) => <li>{item}</li>)}
          </ul>

          <p class="hero__bio">{cv.bio}</p>

          <div class="hero__actions noprint">
            <a class="button button--primary" href="#experience">
              Explore experience
            </a>
            <a
              class="button button--secondary button--download"
              href={pdfCvPath}
              download="Antoine_Jaussoin_CV.pdf"
              type="application/pdf"
            >
              <span
                class="button__icon-wrap button__icon-wrap--pdf"
                aria-hidden="true"
              >
                <svg class="button__icon" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M14.5 2.75H8A2.75 2.75 0 0 0 5.25 5.5v13A2.75 2.75 0 0 0 8 21.25h8A2.75 2.75 0 0 0 18.75 18.5V8.75L14.5 2.75Z"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linejoin="round"></path>
                  <path
                    d="M14.5 2.75V7A1.75 1.75 0 0 0 16.25 8.75h2.5"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                  <path
                    d="M9 10.25h6M9 12.25h6"
                    stroke="currentColor"
                    stroke-width="1.35"
                    stroke-linecap="round"
                    opacity="0.75"></path>
                  <rect
                    x="4"
                    y="14.25"
                    width="16"
                    height="4.75"
                    rx="2"
                    fill="currentColor"></rect>
                  <text
                    x="12"
                    y="17.5"
                    text-anchor="middle"
                    font-size="4.7"
                    font-family="IBM Plex Sans, sans-serif"
                    font-weight="700"
                    fill="#ffffff">PDF</text
                  >
                </svg>
              </span>
              <span class="button__content">
                <span>Download (PDF)</span>
                <span class="button__meta">Print-ready</span>
              </span>
            </a>
            <a
              class="button button--secondary button--download"
              href={wordCvPath}
              download="Antoine_Jaussoin_CV.rtf"
              type="application/rtf"
            >
              <span
                class="button__icon-wrap button__icon-wrap--word"
                aria-hidden="true"
              >
                <svg class="button__icon" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M14.5 2.75H8A2.75 2.75 0 0 0 5.25 5.5v13A2.75 2.75 0 0 0 8 21.25h8A2.75 2.75 0 0 0 18.75 18.5V8.75L14.5 2.75Z"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linejoin="round"
                    opacity="0.92"></path>
                  <path
                    d="M14.5 2.75V7A1.75 1.75 0 0 0 16.25 8.75h2.5"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    opacity="0.92"></path>
                  <path
                    d="M13.75 11.25h3M13.75 14.25h3M13.75 17.25h2.25"
                    stroke="currentColor"
                    stroke-width="1.35"
                    stroke-linecap="round"
                    opacity="0.78"></path>
                  <rect
                    x="3"
                    y="8.25"
                    width="8"
                    height="9.5"
                    rx="2"
                    fill="currentColor"></rect>
                  <text
                    x="7"
                    y="14.5"
                    text-anchor="middle"
                    font-size="6.4"
                    font-family="Space Grotesk, sans-serif"
                    font-weight="700"
                    fill="#ffffff">W</text
                  >
                </svg>
              </span>
              <span class="button__content">
                <span>Download (RTF)</span>
                <span class="button__meta">Recruiter-friendly</span>
              </span>
            </a>
          </div>

          <section class="hero__profile" id="profile">
            <div class="section-heading">
              <p class="section-heading__eyebrow">Profile</p>
              <h2>Professional Profile</h2>
            </div>
            <Profile profile={cv.profile} />
          </section>
        </section>

        <aside class="hero__aside">
          <div class="portrait-card">
            <Picture
              src={portraitSrc}
              formats={["avif", "webp"]}
              widths={[150, 300, 500]}
              sizes="(min-width: 1200px) 18rem, (min-width: 900px) 28vw, 90vw"
              alt={`Portrait of ${cv.name}`}
              class="portrait-card__image"
              loading="eager"
            />
          </div>

          <section class="contact-card" id="contact">
            <div class="section-heading section-heading--compact">
              <p class="section-heading__eyebrow">Contact</p>
              <h2>Connect directly.</h2>
            </div>

            <div class="contact-card__grid">
              <div class="contact-card__item">
                <span class="meta-label">Email</span>
                <MailTo email={cv.email} obfuscate={true}>
                  {cv.email.replace("@", " (at) ")}
                </MailTo>
              </div>

              <div class="contact-card__item">
                <span class="meta-label">Phone</span>
                <a href={phoneHref}>{cv.phone}</a>
              </div>

              <div class="contact-card__item">
                <span class="meta-label">Website</span>
                <a href={cv.website}>{personalSite}</a>
              </div>

              <div class="contact-card__item">
                <span class="meta-label">Location</span>
                <span>{cv.address2}</span>
              </div>
            </div>

            <ul class="social-grid" aria-label="Social links">
              {
                socialLinks.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="social-grid__link"
                      aria-label={link.label}
                    >
                      <span>{link.label}</span>
                      <span>{link.detail}</span>
                    </a>
                  </li>
                ))
              }
            </ul>
          </section>
        </aside>
      </header>

      <div class="content-layout">
        <div class="main-column">
          <section class="section-card" id="experience">
            <div class="section-heading section-heading--split">
              <div>
                <p class="section-heading__eyebrow">Career</p>
                <h2>Work Experience</h2>
              </div>

              <label class="detail-toggle noprint">
                <span>Detailed mode</span>
                <span class="detail-toggle__control">
                  <input type="checkbox" id="work-details-toggle" checked />
                  <span class="detail-toggle__track"></span>
                </span>
              </label>
            </div>

            <div class="experience-list" data-details-container>
              {sortedWork.map((item) => <Work item={item} />)}
            </div>
          </section>
        </div>

        <aside class="side-column">
          <section class="section-card" id="skills">
            <div class="section-heading">
              <p class="section-heading__eyebrow">Capabilities</p>
              <h2>Technical Skills</h2>
            </div>

            <div class="skill-grid" data-details-container>
              {cv.skills.map((item) => <Skills item={item} />)}
            </div>
          </section>

          <section class="section-card" id="education">
            <div class="section-heading">
              <p class="section-heading__eyebrow">Background</p>
              <h2>Education</h2>
            </div>

            <div class="education-list" data-details-container>
              {sortedEducation.map((item) => <Education item={item} />)}
            </div>
          </section>
        </aside>
      </div>

      <footer class="page-footer">
        <p>&copy; 2026 {cv.name}</p>
        <a href={cv.website}>{personalSite}</a>
      </footer>
    </main>
  </div>
</BaseLayout>

<script>
  const toggle = document.getElementById(
    "work-details-toggle",
  ) as HTMLInputElement | null;
  const detailContainers = document.querySelectorAll(
    "[data-details-container]",
  );
  if (toggle && detailContainers.length > 0) {
    const syncDetails = () => {
      detailContainers.forEach((container) => {
        container.classList.toggle("details-collapsed", !toggle.checked);
      });
    };

    syncDetails();
    toggle.addEventListener("change", syncDetails);
  }
</script>
