---
import type { Picture } from "../types";

interface Props {
  sources: Picture[];
  alt: string;
  class?: string;
  sizes?: string;
  loading?: "lazy" | "eager";
  style?: string;
}

const {
  sources,
  alt,
  class: className,
  sizes,
  loading = "lazy",
  style,
} = Astro.props;

function resolveSrc(src: any): string {
  return typeof src === "object" && src !== null && "src" in src
    ? src.src
    : src;
}

const mainSrc = resolveSrc(sources[0].src);
const set = sources
  .map((s) => resolveSrc(s.src) + " " + s.width + "w")
  .join(", ");
---

<img
  src={mainSrc}
  alt={alt}
  class={className}
  style={style}
  srcset={set}
  sizes={sizes}
  loading={loading}
  decoding="async"
/>
