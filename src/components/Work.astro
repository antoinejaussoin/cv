---
import type { Job, DateRange } from "../types";
import { marked } from "marked";
import Pill from "./Pill.astro";

interface Props {
  item: Job;
}

const { item } = Astro.props;
const descriptionHtml = await marked.parse(item.description);
const shortDescriptionHtml = await marked.parse(item.shortDescription);
const monthYearFormatter = new Intl.DateTimeFormat("en-GB", {
  month: "long",
  year: "numeric",
});

function formatWebsite(url: string) {
  try {
    return new URL(url).hostname.replace(/^www\./, "");
  } catch {
    return url;
  }
}

function buildPeriod(dates: DateRange) {
  const from = monthYearFormatter.format(new Date(dates.from));
  if (!dates.to) {
    return from + " - Present";
  }
  const to = monthYearFormatter.format(new Date(dates.to));
  return from + " - " + to;
}
---

<article class="experience-card">
  <div class="experience-card__header">
    <div>
      <p class="experience-card__meta">
        {item.company} · {item.location} · {item.type}
      </p>
      <h3>{item.title}</h3>
    </div>
    <p class="period-badge">{buildPeriod(item.dates)}</p>
  </div>

  {
    item.techs.length > 0 && (
      <ul class="tag-list" aria-label={`${item.title} technologies`}>
        {item.techs.map((t) => (
          <li>
            <Pill text={t} />
          </li>
        ))}
      </ul>
    )
  }

  <a class="experience-card__link" href={item.website}>
    {formatWebsite(item.website)}
  </a>

  <div class="rich-text work-description work-description--short" set:html={shortDescriptionHtml} />
  <div class="rich-text work-description" set:html={descriptionHtml} />
</article>
