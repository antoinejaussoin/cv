---
import type { Skill } from "../types";
import { marked } from "marked";
import Pill from "./Pill.astro";

interface Props {
  item: Skill;
}

const { item } = Astro.props;
const descriptionHtml = await marked.parse(item.description);
const shortDescriptionHtml = await marked.parse(item.shortDescription);
const yearsOfExperience = Math.max(
  new Date().getFullYear() - item.startYear,
  0,
);
---

<article class="skill-card">
  <div class="skill-card__header">
    <div>
      <h3>{item.name}</h3>
      <p class="skill-card__meta">{item.level}</p>
    </div>
    <p class="skill-card__years">
      <span>{yearsOfExperience}</span>
      yrs
    </p>
  </div>

  {
    item.related && item.related.length > 0 && (
      <ul
        class="tag-list tag-list--compact"
        aria-label={`${item.name} related tools`}
      >
        {item.related.map((t) => (
          <li>
            <Pill text={t} />
          </li>
        ))}
      </ul>
    )
  }

  <div
    class="rich-text skill-card__description skill-card__description--short"
    set:html={shortDescriptionHtml}
  />
  <div class="rich-text skill-card__description" set:html={descriptionHtml} />
</article>
